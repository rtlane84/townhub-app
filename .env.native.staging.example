# Native iOS staging build — copy to `.env.native.staging` at repo root.
# NEVER commit `.env.native.staging` (real keys/secrets).
#
# Load before ios:sync:
#   set -a && source .env.native.staging && set +a
#   pnpm --filter @workspace/townhub run ios:sync
#
# Do NOT copy VITE_CLERK_PROXY_URL from root `.env` — native loads Clerk from CDN.

DEPLOYMENT_ENVIRONMENT=staging
VITE_DISTRIBUTION_CHANNEL=app-store
VITE_API_BASE_URL=https://api-staging.townhub.io
VITE_PUBLIC_WEB_URL=https://staging.townhub.io
VITE_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME
VITE_SENTRY_DSN=https://REPLACE_ME@o000.ingest.us.sentry.io/000

# Native Google Sign-In (optional until Google Cloud iOS + Web clients exist):
# VITE_GOOGLE_IOS_CLIENT_ID=123456789-xxxx.apps.googleusercontent.com
# VITE_GOOGLE_SERVER_CLIENT_ID=123456789-yyyy.apps.googleusercontent.com
# (Web client ID = ID token audience for Clerk; also enable Clerk Google custom credentials)
