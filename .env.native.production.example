# Native iOS production / App Store candidate build — copy to `.env.native.production`
# at repo root. NEVER commit `.env.native.production` (real keys/secrets).
#
# Load before ios:sync:
#   set -a && source .env.native.production && set +a
#   pnpm --filter @workspace/townhub run ios:sync
#
# Do NOT copy VITE_CLERK_PROXY_URL from root `.env` — native loads Clerk from CDN.
# Internal TestFlight may use `.env.native.staging` instead; App Store uses production.

DEPLOYMENT_ENVIRONMENT=production
VITE_DISTRIBUTION_CHANNEL=app-store
VITE_API_BASE_URL=https://api.townhub.io
VITE_PUBLIC_WEB_URL=https://townhub.io
VITE_CLERK_PUBLISHABLE_KEY=pk_live_REPLACE_ME
VITE_SENTRY_DSN=https://REPLACE_ME@o000.ingest.us.sentry.io/000

# Native Google Sign-In (required for Google on device):
# VITE_GOOGLE_IOS_CLIENT_ID=123456789-xxxx.apps.googleusercontent.com
# VITE_GOOGLE_SERVER_CLIENT_ID=123456789-yyyy.apps.googleusercontent.com
# (Web client ID = ID token audience for Clerk; Production Clerk Google custom credentials ON)
