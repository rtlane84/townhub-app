{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "export NODE_ENV=development && pnpm run build && node --enable-source-maps --import ./dist/instrument.mjs --env-file=../../.env ./dist/index.mjs",
    "build": "node ./build.mjs",
    "start": "node --enable-source-maps --import ./dist/instrument.mjs ./dist/index.mjs",
    "test": "node --import tsx/esm --test src/**/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "relink-clerk-user": "node --import tsx/esm --env-file=../../.env ./scripts/relink-clerk-user.ts",
    "assign-dev-clerk-accounts": "node --import tsx/esm --env-file=../../.env ./scripts/assign-dev-clerk-accounts.ts"
  },
  "dependencies": {
    "@clerk/backend": "^3.8.2",
    "@clerk/express": "^2.1.30",
    "@clerk/shared": "^4.20.0",
    "@sentry/node": "^10.63.0",
    "@supabase/supabase-js": "^2.86.0",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "drizzle-orm": "catalog:",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.0",
    "http-proxy-middleware": "^4.1.1",
    "multer": "^2.0.2",
    "nodemailer": "^9.0.1",
    "pino": "^9.14.0",
    "pino-http": "^10.5.0",
    "resend": "^6.14.0",
    "sharp": "^0.35.3",
    "stripe": "^22.2.3",
    "twilio": "^6.0.2",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.0.0",
    "@types/node": "catalog:",
    "@types/nodemailer": "^8.0.1",
    "esbuild": "0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13.1.3",
    "thread-stream": "3.1.0",
    "tsx": "catalog:"
  }
}
