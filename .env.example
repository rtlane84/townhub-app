# TownHub — Environment Variable Template

Copy this file to `.env` at the repository root and fill in values.
# NEVER commit `.env` to source control.

# Both the API server and Vite frontend read from this single root `.env`.

# ── Database ──────────────────────────────────────────────
DATABASE_URL=
# Optional pool tuning (defaults are safe for local dev and small beta deploys)
# DATABASE_POOL_MAX=10
# DATABASE_CONNECTION_TIMEOUT_MS=10000
# DATABASE_IDLE_TIMEOUT_MS=30000
# DATABASE_QUERY_TIMEOUT_MS=30000

# ── Clerk Auth ────────────────────────────────────────────
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
VITE_CLERK_PUBLISHABLE_KEY=
# Local dev: proxy Clerk through the API server
# Replit preview: leave empty (Clerk loads from CDN)
VITE_CLERK_PROXY_URL=http://localhost:8080/api/__clerk

# ── Session / Guest Order Tokens ──────────────────────────
# Required in production (≥ 32 characters).
# Signs HMAC guest order access tokens for confirmation pages and Stripe checkout.
# Generate: openssl rand -base64 32
SESSION_SECRET=

# Optional: require a shared secret for first-admin bootstrap (POST /api/admin/bootstrap).
# Send as JSON body { "token": "..." } or header X-Bootstrap-Token.
# BOOTSTRAP_TOKEN=

# ── Application URL ───────────────────────────────────────
# Public frontend URL — Stripe redirects, notification links, checkout success URLs
APP_BASE_URL=http://localhost:23032
# iOS Capacitor shell — must match APP_BASE_URL in production (see docs/IOS_APP.md)
# CAPACITOR_SERVER_URL=https://your-townhub.netlify.app
# Split deploy (Netlify frontend + Railway API): set at Netlify build time so the
# browser calls Railway instead of relative /api on the Netlify host.
# Leave empty for local Vite (dev server proxies /api → localhost:8080).
# VITE_API_BASE_URL=https://town-hub-production.up.railway.app
# Production only: comma-separated extra browser origins allowed by API CORS
# (APP_BASE_URL origin is always included). Example preview/staging frontends:
# CORS_ALLOWED_ORIGINS=https://preview.example.com,https://staging.example.com
# CORS_ALLOWED_ORIGINS=

# ── Stripe (platform — Connect + Billing) ───────────────────
# See docs/STRIPE_SETUP.md and docs/STRIPE_BILLING_SETUP.md
STRIPE_SECRET_KEY=
# Connected accounts destination (customer orders + refunds)
STRIPE_CONNECT_WEBHOOK_SECRET=
# Your account destination (owner subscriptions)
STRIPE_PLATFORM_WEBHOOK_SECRET=
# Optional legacy fallback (single destination only)
STRIPE_WEBHOOK_SECRET=

# ── Email (Resend or SMTP) ────────────────────────────────
# Option A — Resend (preferred). BOTH vars required when using Resend.
RESEND_API_KEY=
RESEND_FROM=

# Option B — SMTP fallback (leave RESEND_API_KEY unset)
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=

# ── SMS (Twilio — optional) ─────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── Free phone push (ntfy — optional) ───────────────────────
# Public ntfy server by default. Change to your own ntfy base URL later to self-host.
NTFY_SERVER_URL=https://ntfy.sh

# ── Native / Web Push (optional) ────────────────────────────
# iOS — APNs token authentication (.p8 key). Required for Capacitor push.
# APNS_KEY_ID=
# APNS_TEAM_ID=
# APNS_BUNDLE_ID=com.lanetech.townhub
# APNS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# APNS_PRIVATE_KEY_PATH=
# APNS_PRODUCTION=false

# Android — Firebase Cloud Messaging (future)
# FCM_PROJECT_ID=
# FCM_CLIENT_EMAIL=
# FCM_PRIVATE_KEY=

# Web Push — VAPID (future)
# WEB_PUSH_VAPID_PUBLIC_KEY=
# WEB_PUSH_VAPID_PRIVATE_KEY=
# WEB_PUSH_VAPID_SUBJECT=mailto:admin@example.com

# ── Media / Image Storage (Supabase) ───────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=
# Dev-only fallback: MEDIA_STORAGE=local

# ── Error Monitoring (Sentry — optional) ────────────────────
SENTRY_DSN=
VITE_SENTRY_DSN=
# APP_VERSION=1.0.0
# GIT_COMMIT_SHA=
# VITE_APP_VERSION=1.0.0
# VITE_GIT_COMMIT_SHA=

# ── Internal Jobs and Admin Alerts ──────────────────────────
# Generate: openssl rand -base64 32
JOB_SECRET=
# JOB_CRON_CONFIGURED=true
PLATFORM_ADMIN_EMAIL=

# ── Rate Limiting (optional overrides) ──────────────────────
# RATE_LIMIT_DISABLED=false
# RATE_LIMIT_TRUST_PROXY=true
# RATE_LIMIT_WRITE_MAX=60
# RATE_LIMIT_WRITE_WINDOW_MS=900000
# RATE_LIMIT_READ_MAX=120
# RATE_LIMIT_READ_WINDOW_MS=900000
# RATE_LIMIT_ORDER_LOOKUP_MAX=30
# RATE_LIMIT_ORDER_LOOKUP_WINDOW_MS=900000
# RATE_LIMIT_GENERAL_MAX=300
# RATE_LIMIT_GENERAL_WINDOW_MS=900000

# ── Runtime ───────────────────────────────────────────────
PORT=8080
NODE_ENV=development
