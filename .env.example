# TownHub — Environment Variable Template
#
# Copy to `.env` at the repository root and fill in values.
# NEVER commit `.env` to source control.
#
# Both the API server and Vite frontend read from this single root `.env`.
# This file is the full catalog of app/runtime variables. Deployed hosts use
# subsets: see docs/ENVIRONMENTS.md for Railway API and Cloudflare build checklists.
# GitHub Actions backup secrets are listed at the bottom (not for local `.env`).

# ── Deployment environment ────────────────────────────────
# Required on staging/production hosts: staging | production
# DEPLOYMENT_ENVIRONMENT=staging
# Vite usually maps DEPLOYMENT_ENVIRONMENT → import.meta.env.VITE_DEPLOYMENT_ENVIRONMENT.
# Override only if the frontend build must tag a different Sentry environment:
# VITE_DEPLOYMENT_ENVIRONMENT=staging

# ── Database ──────────────────────────────────────────────
DATABASE_URL=
# Optional pool tuning (defaults are safe for local dev).
# Staging/production Railway: set DATABASE_POOL_MAX=20 (or 25) and use the
# Supabase Session Pooler URI (port 5432) — see PRODUCTION.md.
# DATABASE_POOL_MAX=10
# DATABASE_CONNECTION_TIMEOUT_MS=10000
# DATABASE_IDLE_TIMEOUT_MS=30000
# DATABASE_QUERY_TIMEOUT_MS=30000

# ── Clerk Auth ────────────────────────────────────────────
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
VITE_CLERK_PUBLISHABLE_KEY=
# Local dev: proxy Clerk through the API server. Leave unset for native app-store builds.
VITE_CLERK_PROXY_URL=http://localhost:8080/api/__clerk

# ── Session / Guest Order Tokens ──────────────────────────
# Required in production (≥ 32 characters).
# Signs HMAC guest order access tokens for confirmation pages and Stripe checkout.
# Generate: openssl rand -base64 32
SESSION_SECRET=

# Optional: require a shared secret for first-admin bootstrap (POST /api/admin/bootstrap).
# Send as JSON body { "token": "..." } or header X-Bootstrap-Token.
# BOOTSTRAP_TOKEN=

# ── Application URL / CORS ────────────────────────────────
# Public frontend URL — Stripe redirects, notification links, checkout success URLs
APP_BASE_URL=http://localhost:23032
# Optional when APP_BASE_URL wrongly points at the API host; prefer the public web origin.
# FRONTEND_BASE_URL=https://townhub.io
# Public HTTPS web origin used by native OAuth and browser return bridges.
# Required at native build time; native app code itself is bundled by Capacitor.
# VITE_PUBLIC_WEB_URL=https://app.example.com
# Browser deployments use web. Native release builds should use app-store.
# VITE_DISTRIBUTION_CHANNEL=web
# Split deploy: set at Cloudflare (or native) build time so the client calls Railway.
# Leave empty for local Vite (dev server proxies /api → localhost:8080).
# VITE_API_BASE_URL=https://api.townhub.io
# Production: comma-separated extra browser origins for API CORS (APP_BASE_URL always included).
# CORS_ALLOWED_ORIGINS=https://preview.example.com,https://staging.example.com
# Store builds use a fixed local WebView origin. Configure explicitly on the API.
# NATIVE_ALLOWED_ORIGINS=capacitor://localhost
# Optional site URL used in address-geocode User-Agent fallback (Nominatim etiquette).
# PLATFORM_URL=https://townhub.io
# GEOCODE_USER_AGENT=TownHub/1.0 (contact@example.com)

# Native Google Sign-In (iOS Capacitor builds; also in .env.native.*.example)
# VITE_GOOGLE_IOS_CLIENT_ID=
# VITE_GOOGLE_SERVER_CLIENT_ID=

# ── Stripe (platform — Connect + Billing) ───────────────────
# See docs/STRIPE_SETUP.md and docs/STRIPE_BILLING_SETUP.md
STRIPE_SECRET_KEY=
# Connected accounts destination (customer orders + refunds)
STRIPE_CONNECT_WEBHOOK_SECRET=
# Your account destination (owner subscriptions)
STRIPE_PLATFORM_WEBHOOK_SECRET=
# Optional legacy fallback (single destination only) — omit when Connect + platform secrets are set
STRIPE_WEBHOOK_SECRET=

# ── Email (Resend or SMTP) ────────────────────────────────
# Option A — Resend (preferred). BOTH vars required when using Resend.
RESEND_API_KEY=
RESEND_FROM=

# Inbox for customer “Report a problem” submissions (defaults to Ronnie@LaneTechWV.com)
# SUPPORT_INBOX_EMAIL=

# Option B — SMTP fallback (leave RESEND_API_KEY unset)
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=

# ── SMS (Twilio — optional) ─────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── Free phone push (ntfy — optional) ───────────────────────
# Public ntfy server by default. Change to your own ntfy base URL later to self-host.
NTFY_SERVER_URL=https://ntfy.sh

# ── Native / Web Push (optional) ────────────────────────────
# iOS — APNs token authentication (.p8 key). Required for Capacitor push.
# APNS_KEY_ID=
# APNS_TEAM_ID=
# APNS_BUNDLE_ID=com.lanetech.townhub
# APNS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# APNS_PRIVATE_KEY_PATH=
# APNS_PRODUCTION=false

# Android — Firebase Cloud Messaging (future)
# FCM_PROJECT_ID=
# FCM_CLIENT_EMAIL=
# FCM_PRIVATE_KEY=

# Web Push — VAPID (future)
# WEB_PUSH_VAPID_PUBLIC_KEY=
# WEB_PUSH_VAPID_PRIVATE_KEY=
# WEB_PUSH_VAPID_SUBJECT=mailto:admin@example.com

# ── WeatherKit (Apple Weather REST API) ─────────────────────
# See docs/WEATHERKIT.md. Keep the private key server-side; never expose to the frontend.
# WEATHERKIT_KEY_ID=
# WEATHERKIT_TEAM_ID=
# WEATHERKIT_SERVICE_ID=
# WEATHERKIT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# WEATHERKIT_PRIVATE_KEY_PATH=
# Coordinates for the configured weatherLocation (WeatherKit has no geocoder).
# WEATHERKIT_LATITUDE=
# WEATHERKIT_LONGITUDE=
# WEATHERKIT_TIMEZONE=America/New_York
# Demo forecast fallback. Prefer unset or false on production.
# When unset: demo only if NODE_ENV !== "production".
# WEATHER_DEMO_FALLBACK=false

# ── Media / Image Storage (Supabase) ───────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=
# Dev-only: write uploads to the local filesystem instead of Supabase.
# MEDIA_STORAGE=local
# MEDIA_UPLOAD_DIR=./uploads

# ── Error Monitoring (Sentry — optional) ────────────────────
SENTRY_DSN=
VITE_SENTRY_DSN=
# Prefer DEPLOYMENT_ENVIRONMENT for Sentry/Better Stack env tags (staging|production).
# APP_VERSION=1.0.0
# GIT_COMMIT_SHA=
# VITE_APP_VERSION=1.0.0
# VITE_GIT_COMMIT_SHA=
# Optional Ops Center display overrides
# APP_NAME=TownHub
# API_VERSION=1.0.0
# LOG_LEVEL=info

# ── Internal Jobs and Admin Alerts ──────────────────────────
# Generate: openssl rand -base64 32
JOB_SECRET=
# Set true only when an external cron actually calls the trial-reminder job.
# JOB_CRON_CONFIGURED=true
PLATFORM_ADMIN_EMAIL=

# ── Rate Limiting (optional overrides) ──────────────────────
# RATE_LIMIT_DISABLED=false
# RATE_LIMIT_TRUST_PROXY=true
# RATE_LIMIT_WRITE_MAX=60
# RATE_LIMIT_WRITE_WINDOW_MS=900000
# RATE_LIMIT_READ_MAX=120
# RATE_LIMIT_READ_WINDOW_MS=900000
# RATE_LIMIT_ORDER_LOOKUP_MAX=30
# RATE_LIMIT_ORDER_LOOKUP_WINDOW_MS=900000
# RATE_LIMIT_GENERAL_MAX=300
# RATE_LIMIT_GENERAL_WINDOW_MS=900000

# ── Runtime ───────────────────────────────────────────────
PORT=8080
NODE_ENV=development
# Required in production before business listing applications can be accepted.
# Set only after written counsel approval.
# BUSINESS_SELLER_AGREEMENT_APPROVED_VERSION=2026-07-21

# Vite build base path (host tooling; often set by the deploy platform).
# BASE_PATH=/

# ── Dev scripts only (never required on Railway/Cloudflare) ─
# docs/DEV_CLERK_RELINK.md — assign-dev-clerk-accounts.ts
# ADMIN_CLERK_USER_ID=
# DINER_CLERK_USER_ID=
# artifacts/api-server/scripts/ensure-launch-plans.ts — required to seed when NODE_ENV=production
# ALLOW_LAUNCH_PLAN_SEED=1

# ── Playwright E2E (optional overrides) ───────────────────
# See docs/PLAYWRIGHT_E2E.md and docs/TESTING.md
# E2E_BASE_URL=http://localhost:23032
# E2E_API_URL=http://localhost:8080
# E2E_BUSINESS_SLUG=
# E2E_STRIPE_CHECKOUT=1

# ── Legacy Replit host (do not set on Railway/Cloudflare) ──
# REPLIT_DOMAINS=
# REPL_ID=

# ── GitHub Actions secrets (backup/restore — NOT for local .env) ──
# Documented in docs/DATABASE_BACKUP_AND_RECOVERY.md
# SUPABASE_DB_URL=
# CF_ACCESS_KEY_ID=
# CF_SECRET_ACCESS_KEY=
# CF_BUCKET_NAME=
# CF_BUCKET_ENDPOINT=
