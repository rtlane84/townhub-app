# ─────────────────────────────────────────────────────────
# LocalOrderHub — environment variable template
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
# ─────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────
# PostgreSQL connection string.
# On Replit this is provisioned automatically.
# Locally: postgres://user:password@localhost:5432/localorderhub
DATABASE_URL=

# ── Clerk Auth ────────────────────────────────────────────
# From: Clerk Dashboard → API Keys
# Both keys are required; the publishable key is also needed
# in the frontend .env (see below).
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=

# ── Session ───────────────────────────────────────────────
# Any random string ≥ 32 characters. Used for session signing.
# Generate one with: openssl rand -base64 32
SESSION_SECRET=

# ── Stripe Connect (platform) ─────────────────────────────
# Platform secret key. Enables Connect onboarding + webhooks.
# See docs/STRIPE_SETUP.md (Part A — platform owner).
# Platform subscriptions (businesses paying TownHub): docs/STRIPE_BILLING_SETUP.md
STRIPE_SECRET_KEY=

# Required when STRIPE_SECRET_KEY is set. From platform webhook endpoint or Stripe CLI.
# Used for both Stripe Connect order events and platform subscription billing events.
STRIPE_WEBHOOK_SECRET=

# ── Email Notifications ───────────────────────────────────
# Optional. If neither is set, notification logging still
# works but no emails are actually sent.

# Option A — Resend (https://resend.com)
RESEND_API_KEY=

# Option B — SMTP (any provider)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ── SMS Notifications (Twilio) ────────────────────────────
# Optional. Platform-level SMS for urgent owner alerts.
# From: Twilio Console → Account Info / Phone Numbers
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Public app URL for Stripe return links, checkout redirects, and owner notification links.
# Example: http://localhost:5173
APP_BASE_URL=

# Shared secret for internal scheduled jobs (trial reminder emails, etc.).
# Generate with: openssl rand -base64 32
# Cron example (daily 9am UTC):
# curl -X POST -H "Authorization: Bearer $JOB_SECRET" https://api.yourtown.com/api/internal/jobs/subscription-trial-reminders
JOB_SECRET=

# Comma-separated platform admin emails for subscription operational alerts.
# Falls back to all users with the ADMIN role when unset.
PLATFORM_ADMIN_EMAIL=

# ── Media / Image Storage (Supabase) ───────────────────────
# Required for image uploads (default storage backend).
# Create a public bucket in Supabase Storage and use the service role key
# server-side only — never expose it to the browser.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=

# Optional dev-only fallback: set MEDIA_STORAGE=local to write files to ./uploads
# instead of Supabase. Not used in production.
# MEDIA_STORAGE=local
# MEDIA_UPLOAD_DIR=./uploads

# ── Runtime (set automatically by Replit workflows) ───────
# Do not set these manually in Replit — the workflow system
# injects them. Set them yourself only when running locally.
PORT=8080
NODE_ENV=development

# ─────────────────────────────────────────────────────────
# FRONTEND (artifacts/local-order-hub/.env)
# These VITE_ variables are needed by the React app.
# ─────────────────────────────────────────────────────────

# Same publishable key as above (safe to expose to browser).
VITE_CLERK_PUBLISHABLE_KEY=

# Proxy URL for Clerk FAPI calls. When running locally point
# this at the local API server. In Replit it is set by the
# artifact system automatically.
# Local value: http://localhost:8080/api/__clerk
VITE_CLERK_PROXY_URL=
