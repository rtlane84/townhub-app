# ─────────────────────────────────────────────────────────
# LocalOrderHub — environment variable template
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
# ─────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────
# PostgreSQL connection string.
# On Replit this is provisioned automatically.
# Locally: postgres://user:password@localhost:5432/localorderhub
DATABASE_URL=

# ── Clerk Auth ────────────────────────────────────────────
# From: Clerk Dashboard → API Keys
# Both keys are required; the publishable key is also needed
# in the frontend .env (see below).
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=

# ── Session ───────────────────────────────────────────────
# Any random string ≥ 32 characters. Used for session signing.
# Generate one with: openssl rand -base64 32
SESSION_SECRET=

# ── Stripe Payments ───────────────────────────────────────
# Optional. If omitted, checkout returns a mock success URL
# (orders are still recorded in the DB with status PAID).
# From: Stripe Dashboard → Developers → API Keys
STRIPE_SECRET_KEY=

# Required when STRIPE_SECRET_KEY is set and you want real
# webhook processing. From: Stripe Dashboard → Webhooks.
STRIPE_WEBHOOK_SECRET=

# ── Email Notifications ───────────────────────────────────
# Optional. If neither is set, notification logging still
# works but no emails are actually sent.

# Option A — Resend (https://resend.com)
RESEND_API_KEY=

# Option B — SMTP (any provider)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ── Runtime (set automatically by Replit workflows) ───────
# Do not set these manually in Replit — the workflow system
# injects them. Set them yourself only when running locally.
PORT=8080
NODE_ENV=development

# ─────────────────────────────────────────────────────────
# FRONTEND (artifacts/local-order-hub/.env)
# These VITE_ variables are needed by the React app.
# ─────────────────────────────────────────────────────────

# Same publishable key as above (safe to expose to browser).
VITE_CLERK_PUBLISHABLE_KEY=

# Proxy URL for Clerk FAPI calls. When running locally point
# this at the local API server. In Replit it is set by the
# artifact system automatically.
# Local value: http://localhost:8080/api/__clerk
VITE_CLERK_PROXY_URL=
